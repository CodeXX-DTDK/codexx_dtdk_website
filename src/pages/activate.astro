---
import StandaloneLayout from '../layouts/StandaloneLayout.astro'
export const prerender = false

const justPurchased = Astro.url.searchParams.get('success') === '1'
const prefillKey = Astro.url.searchParams.get('key') ?? ''
---
<StandaloneLayout
  title="Activate License — codegen"
  description="Validate your codegen license key and see your plan tier and features."
  activeNav="activate"
>
  <style>
    main {
      max-width: 580px;
      margin: 0 auto;
      padding: var(--page-space-16) var(--page-space-6) var(--page-space-24);
    }

    /*Purchase banner */
    .banner {
      background: color-mix(in srgb, var(--page-success) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--page-success) 30%, transparent);
      border-radius: var(--page-radius-xl);
      padding: var(--page-space-4) var(--page-space-5);
      margin-bottom: var(--page-space-8);
      display: flex;
      gap: var(--page-space-3);
      align-items: flex-start;
      font-size: var(--page-font-size-sm);
    }
    .banner-icon { font-size: 1.2rem; flex-shrink: 0; }
    .banner strong { display: block; color: var(--page-success); margin-bottom: 0.15rem; }
    .banner p { color: var(--page-text-muted); }

    /*Page header */
    h1 {
      font-size: 1.9rem;
      font-weight: var(--page-font-weight-extrabold);
      letter-spacing: -0.03em;
      margin-bottom: var(--page-space-2);
      color: var(--page-text);
    }
    .subtitle {
      color: var(--page-text-muted);
      margin-bottom: var(--page-space-10);
      font-size: var(--page-font-size-sm);
    }

    /*Key input */
    .input-group {
      display: flex;
      gap: var(--page-space-2);
      margin-bottom: var(--page-space-4);
    }
    input[type="text"] {
      flex: 1;
      background: var(--page-bg-secondary);
      border: 1px solid var(--page-border);
      border-radius: var(--page-radius-lg);
      padding: 0.75rem var(--page-space-4);
      font-size: var(--page-font-size-sm);
      font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
      color: var(--page-text);
      outline: none;
      transition: border-color 0.15s;
    }
    input[type="text"]:focus { border-color: var(--page-accent); }
    input[type="text"]::placeholder { color: var(--page-text-muted); font-family: var(--page-font-family); }

    /*Status */
    .status-error {
      display: none;
      font-size: var(--page-font-size-sm);
      color: var(--page-error);
      margin-bottom: var(--page-space-2);
    }
    .status-error.visible { display: block; }

    /*Result card */
    #result {
      display: none;
      background: var(--page-bg-secondary);
      border: 1px solid var(--page-border);
      border-radius: var(--page-radius-xl);
      padding: var(--page-space-6) var(--page-space-8);
      margin-top: var(--page-space-6);
      box-shadow: var(--page-shadow-sm);
    }
    #result.visible { display: block; }

    .result-header {
      display: flex;
      align-items: center;
      gap: var(--page-space-3);
      margin-bottom: var(--page-space-6);
    }

    /*CLI command block */
    .cmd-label {
      font-size: var(--page-font-size-xs);
      font-weight: var(--page-font-weight-semibold);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--page-text-muted);
      margin-bottom: var(--page-space-2);
    }
    .cmd-block {
      display: flex;
      align-items: center;
      gap: var(--page-space-3);
      background: var(--page-bg-tertiary);
      border: 1px solid var(--page-border);
      border-radius: var(--page-radius-lg);
      padding: var(--page-space-3) var(--page-space-4);
      margin-bottom: var(--page-space-3);
    }
    .activate-hint {
      font-size: var(--page-font-size-sm);
      color: var(--page-text-muted);
      line-height: 1.55;
      margin-bottom: var(--page-space-6);
    }
    .activate-hint strong {
      color: var(--page-text-secondary);
      font-weight: var(--page-font-weight-semibold);
    }
    .cmd-text {
      flex: 1;
      font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
      font-size: var(--page-font-size-sm);
      color: var(--page-text);
      overflow-x: auto;
      white-space: nowrap;
    }
    .copy-btn {
      background: none;
      border: 1px solid var(--page-border);
      border-radius: var(--page-radius);
      padding: 0.25rem 0.6rem;
      font-size: var(--page-font-size-xs);
      font-family: var(--page-font-family);
      color: var(--page-text-muted);
      cursor: pointer;
      transition: border-color 0.15s, color 0.15s;
      flex-shrink: 0;
    }
    .copy-btn:hover { border-color: var(--page-accent); color: var(--page-text); }
    .copy-btn.copied { border-color: var(--page-success); color: var(--page-success); }

    /*Feature grid */
    .features-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--page-space-2);
      margin-top: var(--page-space-1);
    }
    .feature-item {
      display: flex;
      align-items: center;
      gap: var(--page-space-2);
      font-size: var(--page-font-size-xs);
      color: var(--page-text-muted);
    }
    .feature-item.on { color: var(--page-text-secondary); }
    .feature-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--page-border);
      flex-shrink: 0;
    }
    .feature-item.on .feature-dot { background: var(--page-success); }

    /*Docs hint */
    .docs-hint {
      margin-top: var(--page-space-8);
      font-size: var(--page-font-size-sm);
      color: var(--page-text-muted);
    }
    .docs-hint a { color: var(--page-text); text-decoration: none; }
    .docs-hint a:hover { text-decoration: underline; }
  </style>

  <main>
    {justPurchased && (
      <div class="banner">
        <span class="banner-icon">🎉</span>
        <div>
          <strong>Purchase complete — thank you!</strong>
          <p>Your license key has been emailed to you. Paste it below to verify your plan, then activate it in the CodeXX DTDK manager.</p>
          <p style="margin-top:0.5rem;">Need to manage billing later? Request a one-time portal link at <a href="/portal" style="color:inherit;text-decoration:underline;">/portal</a>.</p>
        </div>
      </div>
    )}

    <h1>Activate your license</h1>
    <p class="subtitle">Paste your license key to verify it and see your tier and features. Activation itself happens in the CodeXX DTDK manager.</p>

    <div id="error-msg" class="status-error" role="alert" aria-live="polite"></div>

    <form id="activate-form" novalidate>
      <div class="input-group">
        <input
          type="text"
          id="license-key"
          name="key"
          placeholder="key/eyJhY2NvdW50…"
          value={prefillKey}
          autocomplete="off"
          autocorrect="off"
          spellcheck="false"
          required
        />
        <button type="submit" id="validate-btn" class="page-button page-button-primary page-button-md">
          Validate
        </button>
      </div>
    </form>

    <div id="result" role="region" aria-label="License details">
      <div class="result-header">
        <span id="tier-badge" class="page-badge page-badge-default"></span>
      </div>

      <p class="cmd-label">Your license key</p>
      <div class="cmd-block">
        <code class="cmd-text" id="cmd-text"></code>
        <button class="copy-btn" id="copy-btn" type="button" aria-label="Copy license key">Copy</button>
      </div>

      <p class="activate-hint">
        To activate, open the <strong>CodeXX DTDK manager</strong>, select the
        <strong>codegen</strong> component and press Enter, then paste this key
        into the activation pane.
      </p>

      <div id="features-grid" class="features-grid"></div>

      <p class="docs-hint">
        Need help? See the <a href="/docs/licensing/activation">Activation guide</a>
        or the <a href="/docs/licensing/tiers">Tiers &amp; Pricing</a> docs.<br>
        Need to manage billing? <a href="/portal">Request a portal link →</a>
      </p>
    </div>
  </main>

  <script>
    const form = document.getElementById('activate-form')!
    const keyInput = document.getElementById('license-key') as HTMLInputElement
    const validateBtn = document.getElementById('validate-btn') as HTMLButtonElement
    const errorMsg = document.getElementById('error-msg')!
    const result = document.getElementById('result')!
    const tierBadge = document.getElementById('tier-badge')!
    const cmdText = document.getElementById('cmd-text')!
    const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement
    const featuresGrid = document.getElementById('features-grid')!

    const FEATURE_LABELS: Record<string, string> = {
      commercialUse:      'Commercial use',
      tuiDiffViewer:      'Interactive diff viewer',
      vscodeDapDebugger:  'VS Code DAP debugger',
      localPersistence:   'Local persistence',
      cmakeIntegration:   'CMake integration',
      sharedPreambleLibs: 'Shared preamble libs',
      prioritySupport:    'Priority support',
    }

    function setError(msg: string) {
      errorMsg.textContent = msg
      errorMsg.classList.add('visible')
      result.classList.remove('visible')
    }

    function clearError() {
      errorMsg.textContent = ''
      errorMsg.classList.remove('visible')
    }

    function showResult(data: any) {
      clearError()
      const tier: string = data.tier ?? 'community'
      tierBadge.textContent = tier.charAt(0).toUpperCase() + tier.slice(1)
      tierBadge.className = tier === 'professional' || tier === 'team'
        ? 'page-badge page-badge-primary'
        : 'page-badge page-badge-default'
      cmdText.textContent = data.key
      featuresGrid.innerHTML = Object.entries(FEATURE_LABELS)
        .map(([key, label]) => {
          const on = !!data.features?.[key]
          return `<div class="feature-item ${on ? 'on' : ''}">
            <span class="feature-dot" aria-hidden="true"></span>
            ${label}
          </div>`
        })
        .join('')
      result.classList.add('visible')
      result.scrollIntoView({ behavior: 'smooth', block: 'nearest' })
    }

    async function submitKey(key: string) {
      if (!key) { setError('Please enter a license key.'); return }

      validateBtn.setAttribute('aria-busy', 'true')
      validateBtn.disabled = true
      validateBtn.textContent = 'Validating…'
      clearError()

      try {
        const res = await fetch('/api/activate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ key }),
        })
        const data = await res.json()
        if (!res.ok) { setError(data.error ?? 'Validation failed. Please check your key.'); return }
        showResult(data)
      } catch {
        setError('Network error — please try again.')
      } finally {
        validateBtn.removeAttribute('aria-busy')
        validateBtn.disabled = false
        validateBtn.textContent = 'Validate'
      }
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault()
      submitKey(keyInput.value.trim())
    })

    // Auto-validate when /activate?key=… is opened from the activation email.
    if (keyInput.value.trim()) submitKey(keyInput.value.trim())

    copyBtn.addEventListener('click', async () => {
      const text = cmdText.textContent ?? ''
      try {
        await navigator.clipboard.writeText(text)
        copyBtn.textContent = 'Copied!'
        copyBtn.classList.add('copied')
        setTimeout(() => { copyBtn.textContent = 'Copy'; copyBtn.classList.remove('copied') }, 2000)
      } catch {
        const sel = window.getSelection()
        const range = document.createRange()
        range.selectNodeContents(cmdText)
        sel?.removeAllRanges()
        sel?.addRange(range)
      }
    })
  </script>
</StandaloneLayout>
