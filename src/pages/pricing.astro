---
import StandaloneLayout from '../layouts/StandaloneLayout.astro'
---
<StandaloneLayout
  title="Pricing — codegen"
  description="Simple, predictable pricing for codegen. Free for open-source. Paid for teams that ship."
  activeNav="pricing"
>
  <style>
    /* Hero */
    .hero {
      text-align: center;
      padding: var(--page-space-20) var(--page-space-6) var(--page-space-12);
    }
    .hero h1 {
      font-size: clamp(2rem, 5vw, 3.2rem);
      font-weight: 800;
      letter-spacing: -0.03em;
      line-height: 1.15;
      margin-bottom: var(--page-space-4);
      color: var(--page-text);
    }
    .hero p {
      color: var(--page-text-muted);
      font-size: 1.1rem;
      max-width: 520px;
      margin: 0 auto;
    }

    /* Tier grid */
    .tiers {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: var(--page-space-6);
      max-width: 1000px;
      margin: 0 auto;
      padding: 0 var(--page-space-6) var(--page-space-20);
    }

    .tier {
      background: var(--page-bg-secondary);
      border: 1px solid var(--page-border);
      border-radius: var(--page-radius-xl);
      padding: var(--page-space-8);
      display: flex;
      flex-direction: column;
      gap: var(--page-space-6);
      position: relative;
      transition: box-shadow 0.15s, transform 0.15s;
    }
    .tier:hover { transform: translateY(-2px); box-shadow: var(--page-shadow-md); }

    .tier.highlight {
      background: var(--page-bg-elevated);
      border-color: var(--blue-500);
      box-shadow: 0 0 0 1px var(--blue-500), var(--page-shadow-lg);
    }
    .tier.highlight::before {
      content: 'Most popular';
      position: absolute;
      top: -12px;
      left: 50%;
      transform: translateX(-50%);
      background: var(--blue-500);
      color: #fff;
      font-size: 0.72rem;
      font-weight: 700;
      padding: 0.2rem 0.75rem;
      border-radius: var(--page-radius-full);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    /* Tier card internals */
    .tier-header { display: flex; align-items: center; gap: var(--page-space-2); }
    .tier-icon { width: 1.4rem; height: 1.4rem; object-fit: contain; flex-shrink: 0; }
    :global([data-theme="dark"]) .tier-icon,
    :global([data-theme="dark"]) .special-card-icon { filter: invert(1); }

    .tier-price { display: flex; align-items: baseline; gap: var(--page-space-1); }
    .price-amount {
      font-size: 2.5rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      color: var(--page-text);
    }
    .price-period { color: var(--page-text-muted); font-size: 0.9rem; }
    .price-prefix { color: var(--page-text-muted); font-size: 1rem; font-weight: 600; margin-right: 2px; }
    .price-secondary { color: var(--page-text-muted); font-size: 0.8rem; margin-top: var(--page-space-1); }
    .volume-hint {
      font-size: 0.75rem;
      color: var(--page-text-muted);
      margin-top: calc(-1 * var(--page-space-2));
      line-height: 1.5;
    }

    /* Billing toggle */
    .billing-toggle {
      display: inline-flex;
      align-items: center;
      gap: var(--page-space-2);
      margin: 0 auto var(--page-space-8);
      padding: var(--page-space-1);
      background: var(--page-bg-secondary);
      border: 1px solid var(--page-border);
      border-radius: var(--page-radius-full);
    }
    .billing-toggle button {
      background: transparent;
      border: none;
      padding: var(--page-space-2) var(--page-space-5);
      border-radius: var(--page-radius-full);
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--page-text-muted);
      cursor: pointer;
      transition: background 0.15s, color 0.15s;
    }
    .billing-toggle button[aria-pressed="true"] {
      background: var(--page-bg-elevated);
      color: var(--page-text);
      box-shadow: var(--page-shadow-sm);
    }
    .billing-toggle .save-badge {
      background: var(--page-success);
      color: #fff;
      font-size: 0.65rem;
      font-weight: 700;
      padding: 0.1rem 0.4rem;
      border-radius: var(--page-radius-full);
      margin-left: var(--page-space-1);
      letter-spacing: 0.04em;
    }
    .billing-toggle-wrap { display: flex; justify-content: center; }

    .tier-desc { color: var(--page-text-muted); font-size: 0.875rem; line-height: 1.5; }

    .features-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: var(--page-space-2);
      flex: 1;
    }
    .features-list li {
      display: flex;
      align-items: flex-start;
      gap: var(--page-space-2);
      font-size: 0.875rem;
      color: var(--page-text-secondary);
    }
    .features-list li .check { color: var(--page-success); flex-shrink: 0; margin-top: 2px; }
    .features-list li .dash  { color: var(--page-border-strong); flex-shrink: 0; margin-top: 2px; }

    .tier .page-button { width: 100%; justify-content: center; }

    .tier-note {
      text-align: center;
      font-size: 0.75rem;
      color: var(--page-text-muted);
      margin-top: calc(-1 * var(--page-space-3));
    }

    /* Error toast */
    #checkout-error {
      display: none;
      position: fixed;
      bottom: var(--page-space-6);
      left: 50%;
      transform: translateX(-50%);
      background: var(--page-error);
      color: #fff;
      padding: var(--page-space-3) var(--page-space-6);
      border-radius: var(--page-radius-lg);
      font-size: 0.875rem;
      z-index: 100;
      box-shadow: var(--page-shadow-lg);
    }

    /* Special cases */
    .special-cases {
      max-width: 1000px;
      margin: 0 auto;
      padding: 0 var(--page-space-6) var(--page-space-20);
    }
    .special-cases h2 {
      text-align: center;
      font-size: 1rem;
      font-weight: 600;
      color: var(--page-text-muted);
      margin-bottom: var(--page-space-6);
    }
    .special-cards {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--page-space-4);
    }
    @media (max-width: 560px) { .special-cards { grid-template-columns: 1fr; } }

    .special-card {
      background: var(--page-bg-secondary);
      border: 1px solid var(--page-border);
      border-radius: var(--page-radius-xl);
      padding: var(--page-space-6);
      display: flex;
      flex-direction: column;
      gap: var(--page-space-3);
    }
    .special-card-icon { width: 2rem; height: 2rem; object-fit: contain; }
    .special-card h3 { font-size: 0.95rem; font-weight: 700; color: var(--page-text); }
    .special-card p { font-size: 0.85rem; color: var(--page-text-muted); line-height: 1.5; flex: 1; }
    .special-card .page-button { width: 100%; justify-content: center; margin-top: var(--page-space-1); }

    /* ── FAQ ───────────────────────────────────────────────────── */
    .faq {
      max-width: 680px;
      margin: 0 auto;
      padding: 0 var(--page-space-6) var(--page-space-20);
    }
    .faq h2 {
      font-size: 1.3rem;
      font-weight: 700;
      margin-bottom: var(--page-space-8);
      letter-spacing: -0.02em;
      color: var(--page-text);
    }
    details { border-top: 1px solid var(--page-border); padding: var(--page-space-4) 0; }
    details:last-child { border-bottom: 1px solid var(--page-border); }
    summary {
      font-weight: 600;
      font-size: 0.9rem;
      cursor: pointer;
      user-select: none;
      list-style: none;
      display: flex;
      justify-content: space-between;
      align-items: center;
      color: var(--page-text);
    }
    summary::after { content: '+'; font-size: 1.1rem; color: var(--page-text-muted); }
    details[open] summary::after { content: '−'; }
    details p {
      margin-top: var(--page-space-3);
      color: var(--page-text-muted);
      font-size: 0.875rem;
      line-height: 1.6;
    }
    details a { color: var(--page-info); text-decoration: none; }
    details a:hover { text-decoration: underline; }
  </style>

  <section class="hero">
    <h1>Simple, predictable pricing.</h1>
    <p>Free for open-source projects. Upgrade when you need commercial use, the diff TUI, or team tooling.</p>
  </section>

  <div class="billing-toggle-wrap">
    <div class="billing-toggle" role="group" aria-label="Billing interval">
      <button id="toggle-month" aria-pressed="true" data-interval="month">Monthly</button>
      <button id="toggle-year"  aria-pressed="false" data-interval="year">Yearly <span class="save-badge">SAVE ~20%</span></button>
    </div>
  </div>

  <div class="tiers">

    <!-- Community -->
    <article class="tier">
      <div class="tier-header">
        <img src="/community_icon.png" alt="" class="tier-icon" />
        <span class="page-badge page-badge-default">Community</span>
      </div>
      <div class="tier-price">
        <span class="price-amount">€0</span>
        <span class="price-period">/ forever</span>
      </div>
      <p class="tier-desc">For open-source projects and personal exploration.</p>
      <ul class="features-list">
        <li><span class="check">✓</span> Core code generation engine</li>
        <li><span class="check">✓</span> All LuaU rule authoring features</li>
        <li><span class="check">✓</span> Unlimited source files</li>
        <li><span class="dash">–</span> Commercial use</li>
        <li><span class="dash">–</span> Interactive diff viewer</li>
        <li><span class="dash">–</span> VS Code DAP debugger</li>
        <li><span class="dash">–</span> Local persistence</li>
      </ul>
      <a href="/getting-started/installation" class="page-button page-button-default page-button-lg">
        Get started free
      </a>
    </article>

    <!-- Professional -->
    <article class="tier highlight">
      <div class="tier-header">
        <img src="/pro_icon.png" alt="" class="tier-icon" />
        <span class="page-badge" style="background:var(--blue-500);border-color:var(--blue-500);color:#fff;">Professional</span>
      </div>
      <div class="tier-price">
        <span class="price-amount" data-price="pro-month">€12</span>
        <span class="price-period" data-period="pro-month">/ month</span>
      </div>
      <p class="price-secondary" data-secondary="pro" style="display:none;">€8.25 / month effective · billed annually</p>
      <p class="tier-desc">For individuals shipping commercial products with codegen.</p>
      <ul class="features-list">
        <li><span class="check">✓</span> Everything in Community</li>
        <li><span class="check">✓</span> Commercial use</li>
        <li><span class="check">✓</span> Interactive diff viewer (TUI)</li>
        <li><span class="check">✓</span> VS Code DAP debugger</li>
        <li><span class="check">✓</span> Local persistence</li>
        <li><span class="check">✓</span> Up to 5 machines</li>
        <li><span class="dash">–</span> CMake integration</li>
      </ul>
      <button class="page-button page-button-lg" id="btn-professional" style="background:var(--blue-500);border-color:var(--blue-500);color:#fff;">
        Start 14-day free trial
      </button>
      <p class="tier-note" data-note="pro-month">14 days free, then billed monthly · cancel anytime</p>
    </article>

    <!-- Team -->
    <article class="tier">
      <div class="tier-header">
        <img src="/team_icon.png" alt="" class="tier-icon" />
        <span class="page-badge page-badge-default">Team</span>
      </div>
      <div class="tier-price">
        <span class="price-prefix">from</span>
        <span class="price-amount" data-price="team-month">€24</span>
        <span class="price-period" data-period="team-month">/ seat / month</span>
      </div>
      <p class="price-secondary" data-secondary="team" style="display:none;">€19.17 / seat / month effective · billed annually</p>
      <p class="volume-hint">Save 15% at 5+ seats, 25% at 20+ seats.</p>
      <p class="tier-desc">For teams that want CMake integration, shared preamble libs, and priority support.</p>
      <ul class="features-list">
        <li><span class="check">✓</span> Everything in Professional</li>
        <li><span class="check">✓</span> CMake integration</li>
        <li><span class="check">✓</span> Shared preamble libraries</li>
        <li><span class="check">✓</span> Priority support</li>
        <li><span class="check">✓</span> Up to 5 machines per seat</li>
      </ul>
      <button class="page-button page-button-default page-button-lg" id="btn-team">
        Start 30-day free trial
      </button>
      <p class="tier-note" data-note="team-month">30 days free, then billed monthly · cancel anytime</p>
    </article>

  </div>

  <section class="special-cases">
    <h2>Different situation?</h2>
    <div class="special-cards">

      <div class="special-card">
        <img src="/open_source_icon.png" alt="" class="special-card-icon" />
        <h3>I'm an Open Source Maintainer</h3>
        <p>If your project is open source and publicly available, you may qualify for a free Professional license. Tell us about your project and we'll sort you out.</p>
        <a href="/contact?type=opensource" class="page-button page-button-default page-button-md">Apply for a free license</a>
      </div>

      <div class="special-card">
        <img src="/enterprise_icon.png" alt="" class="special-card-icon" />
        <h3>We're an Enterprise</h3>
        <p>Large team, air-gapped environment, or need a custom contract? We offer volume pricing, self-hosted validation, and priority SLAs.</p>
        <a href="/contact?type=enterprise" class="page-button page-button-default page-button-md">Talk to us</a>
      </div>

    </div>
  </section>

  <section class="faq">
    <h2>Frequently asked questions</h2>

    <details>
      <summary>What counts as "commercial use"?</summary>
      <p>Any use of codegen in a product or service that generates revenue — including internal tools at a company — requires a Professional or Team license. Open-source projects with no revenue are covered by the Community tier.</p>
    </details>

    <details>
      <summary>How does machine activation work?</summary>
      <p>After purchasing, you'll receive a license key. Run <code>codegen license activate &lt;key&gt;</code> on each machine you want to use. Professional allows up to 5 machines; you can deactivate any time with <code>codegen license deactivate</code>.</p>
    </details>

    <details>
      <summary>What happens if the license server is unreachable?</summary>
      <p>codegen caches a signed token locally after activation. Professional licenses cache for 14 days; the tool keeps working offline throughout that window. See <a href="/licensing/activation">License Activation</a> for details.</p>
    </details>

    <details>
      <summary>How does the free trial work?</summary>
      <p>Professional includes a 14-day free trial; Team includes a 30-day free trial. A card is required at checkout but no charge happens during the trial — cancel before it ends and you're not billed. The trial covers every gated feature of the tier, on every machine you activate.</p>
    </details>

    <details>
      <summary>Can I upgrade or cancel?</summary>
      <p>Yes — monthly plans cancel at any time; annual plans cancel at renewal. Upgrades take effect immediately. Cancelling during a trial costs nothing.</p>
    </details>

    <details>
      <summary>Do you offer volume discounts on Team?</summary>
      <p>Yes — Team is €24 / seat / month at 1–4 seats, €20.40 / seat / month at 5–19 seats (save 15%), and €18 / seat / month at 20+ seats (save 25%). Annual billing stacks ~20% on top. For larger orgs or air-gapped deployments, <a href="/contact?type=enterprise">talk to us</a>.</p>
    </details>
  </section>

  <div id="checkout-error" role="alert"></div>

  <script>
    const errorEl = document.getElementById('checkout-error')!

    function showError(msg: string) {
      errorEl.textContent = msg
      errorEl.style.display = 'block'
      setTimeout(() => { errorEl.style.display = 'none' }, 5000)
    }

    // ── Billing-interval toggle ─────────────────────────────────────────────
    type Interval = 'month' | 'year'
    let currentInterval: Interval = 'month'

    const PRICES: Record<string, { month: { amount: string; period: string }; year: { amount: string; period: string } }> = {
      pro:  { month: { amount: '€12', period: '/ month' },          year: { amount: '€99',  period: '/ year' } },
      team: { month: { amount: '€24', period: '/ seat / month' },   year: { amount: '€230', period: '/ seat / year' } },
    }
    const NOTES: Record<Interval, { pro: string; team: string }> = {
      month: {
        pro:  '14 days free, then billed monthly · cancel anytime',
        team: '30 days free, then billed monthly · cancel anytime',
      },
      year: {
        pro:  '14 days free, then €99/year · ~31% off vs monthly',
        team: '30 days free, then €230/seat/year · ~20% off vs monthly',
      },
    }

    function applyInterval(interval: Interval) {
      currentInterval = interval

      const monthBtn = document.getElementById('toggle-month') as HTMLButtonElement
      const yearBtn = document.getElementById('toggle-year') as HTMLButtonElement
      monthBtn.setAttribute('aria-pressed', String(interval === 'month'))
      yearBtn.setAttribute('aria-pressed',  String(interval === 'year'))

      for (const tier of ['pro', 'team'] as const) {
        const amount = document.querySelector<HTMLElement>(`[data-price="${tier}-month"]`)
        const period = document.querySelector<HTMLElement>(`[data-period="${tier}-month"]`)
        const note   = document.querySelector<HTMLElement>(`[data-note="${tier}-month"]`)
        const sec    = document.querySelector<HTMLElement>(`[data-secondary="${tier}"]`)
        if (amount) amount.textContent = PRICES[tier][interval].amount
        if (period) period.textContent = PRICES[tier][interval].period
        if (note)   note.textContent   = NOTES[interval][tier]
        if (sec)    sec.style.display  = interval === 'year' ? 'block' : 'none'
      }
    }

    document.getElementById('toggle-month')!.addEventListener('click', () => applyInterval('month'))
    document.getElementById('toggle-year')!.addEventListener('click',  () => applyInterval('year'))

    // ── Checkout ───────────────────────────────────────────────────────────
    async function handleCheckout(tier: string, btn: HTMLButtonElement) {
      btn.setAttribute('aria-busy', 'true')
      btn.disabled = true
      const original = btn.textContent
      btn.textContent = 'Redirecting…'

      try {
        const res = await fetch('/api/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ tier, interval: currentInterval }),
        })
        const data = await res.json() as { url?: string; error?: string }
        if (!res.ok || !data.url) throw new Error(data.error ?? 'Checkout failed. Please try again.')
        window.location.href = data.url
      } catch (err: any) {
        showError(err.message ?? 'Something went wrong.')
        btn.removeAttribute('aria-busy')
        btn.disabled = false
        btn.textContent = original
      }
    }

    document.getElementById('btn-professional')!.addEventListener('click', (e) => {
      handleCheckout('professional', e.currentTarget as HTMLButtonElement)
    })
    document.getElementById('btn-team')!.addEventListener('click', (e) => {
      handleCheckout('team', e.currentTarget as HTMLButtonElement)
    })
  </script>
</StandaloneLayout>
