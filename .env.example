# ── Env file layout ───────────────────────────────────────────────────────────
#
#  .env                 committed — non-secret account-level config
#  .env.local           gitignored — WireMock defaults (pnpm dev)
#  .env.sandbox.local   gitignored — real sandbox creds (pnpm dev:sandbox)
#  Vercel dashboard     production — set per environment in Vercel UI
#
# Copy this file to .env.sandbox.local (or .env.local) and fill in the blanks.

# ── Keygen (non-secret, already in .env — do not duplicate) ──────────────────
# KEYGEN_ACCOUNT_ID=ee46e85e-a395-4f97-aae6-cfb2d5a2597b
# KEYGEN_ED25519_PUBLIC_KEY=a86663f06ae9f7d0566cb8f8313a95dd827a1c3b40cb65d7f086382b652bbf43

# ── Keygen secrets ────────────────────────────────────────────────────────────
# Environment token — Dashboard → Environment → Settings → API Tokens
# sandbox:    env-1b592d2dba812d9858aaacbde0649df32009f5afa3478ce7a7f6646dfcf64e6cv3
# production: env-30e7072ffa24cefd9aef8de53e014bfce3e8dd6b23ed7ec2c23aa7a144ee9ecdv3
KEYGEN_TOKEN=env-xxxx

# Sandbox policy IDs (same for sandbox and production if policies are mirrored)
KEYGEN_POLICY_ID_COMMUNITY=e87a8389-3ba9-4128-974b-a5e9b4fc81ec
KEYGEN_POLICY_ID_PROFESSIONAL=fd574caf-ac13-4ea9-8a78-c61b0f936d45
KEYGEN_POLICY_ID_TEAM=34e0231f-5e43-4396-ba1e-3080c1fc574b
# Production policy IDs:
# KEYGEN_POLICY_ID_COMMUNITY=cce0e2e7-f7a3-4fe1-a035-ea9700c07e61
# KEYGEN_POLICY_ID_PROFESSIONAL=90534364-90c5-41ea-929f-019ecb6b5212
# KEYGEN_POLICY_ID_TEAM=07b350c8-9519-4219-845e-64ac81f59c70

# ── Email ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxx

# ── Polar ─────────────────────────────────────────────────────────────────────
# Webhook secret — Polar dashboard → Webhooks → Signing secret
POLAR_WEBHOOK_SECRET=whsec_xxxx
# API token — Polar dashboard → Settings → API
POLAR_ACCESS_TOKEN=polar_oat_xxxx

# Sandbox product IDs
POLAR_PRODUCT_ID_PROFESSIONAL=e194eec3-2d3d-45b1-9142-f60d34c1fdc8
POLAR_PRODUCT_ID_TEAM=acce8699-e003-4bec-899f-ae7d9a7524ef
# Production product IDs: set these in Vercel when going live
# POLAR_PRODUCT_ID_PROFESSIONAL=prod_xxxx
# POLAR_PRODUCT_ID_TEAM=prod_xxxx
