# ── Email ─────────────────────────────────────────────────────────────────────
# Resend API key — Dashboard → API Keys → Create
RESEND_API_KEY=re_xxxx

# ── Polar ─────────────────────────────────────────────────────────────────────
POLAR_WEBHOOK_SECRET=whsec_your_secret_here
POLAR_ACCESS_TOKEN=polar_oat_sandbox_xxxx

# Map Polar product IDs → tiers (Polar sandbox dashboard → Products)
POLAR_PRODUCT_ID_PROFESSIONAL=e194eec3-2d3d-45b1-9142-f60d34c1fdc8
POLAR_PRODUCT_ID_TEAM=acce8699-e003-4bec-899f-ae7d9a7524ef

# ── Keygen ────────────────────────────────────────────────────────────────────
KEYGEN_ACCOUNT_ID=ee46e85e-a395-4f97-aae6-cfb2d5a2597b

# Use an Environment token (NOT an admin token) — Dashboard → Environment → Settings → API Tokens
KEYGEN_TOKEN=env-token-here

# Override for local mock (leave unset for production)
# KEYGEN_API_BASE=http://localhost:4010

# Policy IDs — Keygen sandbox (same UUIDs for production once policies are created there)
KEYGEN_POLICY_ID_COMMUNITY=e87a8389-3ba9-4128-974b-a5e9b4fc81ec
KEYGEN_POLICY_ID_PROFESSIONAL=fd574caf-ac13-4ea9-8a78-c61b0f936d45
KEYGEN_POLICY_ID_TEAM=34e0231f-5e43-4396-ba1e-3080c1fc574b

# ── Ed25519 public key (baked into C++ binary at compile time) ────────────────
# hex-encoded, from Keygen: Dashboard → Environment → Settings → Public Key
# sandbox:    a86663f06ae9f7d0566cb8f8313a95dd827a1c3b40cb65d7f086382b652bbf43
# production: <get from Keygen production environment → Settings → Public Key>
# local mock: 5107f6b493c1997de3ecb68a4411310026e6d9ae32ce50d6182d4d9f9718dfd8 (dev/test-private.pem)
KEYGEN_ED25519_PUBLIC_KEY=a86663f06ae9f7d0566cb8f8313a95dd827a1c3b40cb65d7f086382b652bbf43

