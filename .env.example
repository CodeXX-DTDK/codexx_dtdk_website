# ── Polar ─────────────────────────────────────────────────────────────────────
POLAR_WEBHOOK_SECRET=whsec_your_secret_here
POLAR_ACCESS_TOKEN=polar_oat_sandbox_xxxx

# Map Polar product IDs → tiers (find in Polar dashboard → Products)
POLAR_PRODUCT_ID_PROFESSIONAL=prod_xxxx
POLAR_PRODUCT_ID_TEAM=prod_xxxx

# ── Keygen ────────────────────────────────────────────────────────────────────
KEYGEN_ACCOUNT_ID=your-account-id
KEYGEN_ADMIN_TOKEN=admin-token-here

# Override for local mock (leave unset for production)
# KEYGEN_API_BASE=http://localhost:4010

# Policy IDs (create once in Keygen dashboard, copy IDs here)
KEYGEN_POLICY_ID_COMMUNITY=pol_xxxx
KEYGEN_POLICY_ID_PROFESSIONAL=pol_xxxx
KEYGEN_POLICY_ID_TEAM=pol_xxxx

# ── Ed25519 public key (baked into C++ binary at compile time) ────────────────
# hex-encoded, from Keygen account settings → Public Key
KEYGEN_ED25519_PUBLIC_KEY=hex_encoded_pubkey
