{
  "name": "codexx-website",
  "private": true,
  "type": "module",
  "description": "CodeXX DTDK website monorepo — pure-Astro landing (landing/) + codegen Starlight docs (codegen/).",
  "scripts": {
    "dev": "pnpm --filter landing dev",
    "dev:landing": "pnpm --filter landing dev",
    "dev:codegen": "pnpm --filter codegen dev",
    "build": "pnpm -r build",
    "build:landing": "pnpm --filter landing build",
    "build:codegen": "pnpm --filter codegen build"
  }
}
