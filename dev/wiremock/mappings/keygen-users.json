{
  "mappings": [
    {
      "name": "retrieve-user-by-email-404",
      "request": {
        "method": "GET",
        "urlPattern": "/v1/accounts/[^/]+/users/[^/]+"
      },
      "response": {
        "status": 404,
        "headers": { "Content-Type": "application/vnd.api+json" },
        "jsonBody": {
          "errors": [
            {
              "title": "Not found",
              "code": "NOT_FOUND",
              "detail": "The requested user was not found"
            }
          ]
        }
      }
    },
    {
      "name": "create-user",
      "request": {
        "method": "POST",
        "urlPattern": "/v1/accounts/[^/]+/users"
      },
      "response": {
        "status": 201,
        "headers": { "Content-Type": "application/vnd.api+json" },
        "jsonBody": {
          "data": {
            "id": "usr_mock_{{randomValue type='UUID'}}",
            "type": "users",
            "attributes": {
              "email": "{{jsonPath request.body '$.data.attributes.email'}}",
              "status": "ACTIVE"
            }
          }
        }
      }
    }
  ]
}
