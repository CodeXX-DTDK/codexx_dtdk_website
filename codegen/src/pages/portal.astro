---
import StandaloneLayout from '../layouts/StandaloneLayout.astro'
export const prerender = false
---
<StandaloneLayout
  title="Subscription Portal — codegen"
  description="Get a one-time link to manage your codegen subscription."
  activeNav="portal"
>
  <style>
    main {
      max-width: 580px;
      margin: 0 auto;
      padding: var(--page-space-16) var(--page-space-6) var(--page-space-24);
    }
    h1 {
      font-size: 1.9rem;
      font-weight: var(--page-font-weight-extrabold);
      letter-spacing: -0.03em;
      margin-bottom: var(--page-space-2);
      color: var(--page-text);
    }
    .subtitle {
      color: var(--page-text-muted);
      margin-bottom: var(--page-space-10);
      font-size: var(--page-font-size-sm);
    }

    .input-group {
      display: flex;
      gap: var(--page-space-2);
      margin-bottom: var(--page-space-4);
    }
    input[type="email"] {
      flex: 1;
      background: var(--page-bg-secondary);
      border: 1px solid var(--page-border);
      border-radius: var(--page-radius-lg);
      padding: 0.75rem var(--page-space-4);
      font-size: var(--page-font-size-sm);
      color: var(--page-text);
      outline: none;
      transition: border-color 0.15s;
    }
    input[type="email"]:focus { border-color: var(--page-accent); }
    input[type="email"]::placeholder { color: var(--page-text-muted); }

    .status-error {
      display: none;
      font-size: var(--page-font-size-sm);
      color: var(--page-error);
      margin-bottom: var(--page-space-2);
    }
    .status-error.visible { display: block; }

    #result {
      display: none;
      background: color-mix(in srgb, var(--page-success) 8%, transparent);
      border: 1px solid color-mix(in srgb, var(--page-success) 30%, transparent);
      border-radius: var(--page-radius-xl);
      padding: var(--page-space-5) var(--page-space-6);
      margin-top: var(--page-space-4);
      font-size: var(--page-font-size-sm);
      color: var(--page-text-secondary);
    }
    #result.visible { display: block; }
    #result strong { display: block; color: var(--page-success); margin-bottom: 0.3rem; }

    .docs-hint {
      margin-top: var(--page-space-8);
      font-size: var(--page-font-size-sm);
      color: var(--page-text-muted);
    }
    .docs-hint a { color: var(--page-text); text-decoration: none; }
    .docs-hint a:hover { text-decoration: underline; }
  </style>

  <main>
    <h1>Manage your subscription</h1>
    <p class="subtitle">
      Enter the email you used at checkout. We'll send a one-time link to the
      Polar customer portal where you can update billing, change plan, or cancel.
    </p>

    <div id="error-msg" class="status-error" role="alert" aria-live="polite"></div>

    <form id="portal-form" novalidate>
      <div class="input-group">
        <input
          type="email"
          id="portal-email"
          name="email"
          placeholder="you@example.com"
          autocomplete="email"
          required
        />
        <button type="submit" id="send-btn" class="page-button page-button-primary page-button-md">
          Send link
        </button>
      </div>
    </form>

    <div id="result" role="status" aria-live="polite">
      <strong>Check your inbox</strong>
      If an account exists for that email, we've sent a portal link. The link
      expires shortly — request a new one if needed.
    </div>

    <p class="docs-hint">
      Looking to activate a key instead? Go to <a href="/activate">Activate</a>.
    </p>
  </main>

  <script>
    const form = document.getElementById('portal-form')!
    const emailInput = document.getElementById('portal-email') as HTMLInputElement
    const sendBtn = document.getElementById('send-btn') as HTMLButtonElement
    const errorMsg = document.getElementById('error-msg')!
    const result = document.getElementById('result')!

    function setError(msg: string) {
      errorMsg.textContent = msg
      errorMsg.classList.add('visible')
      result.classList.remove('visible')
    }

    function clearError() {
      errorMsg.textContent = ''
      errorMsg.classList.remove('visible')
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      const email = emailInput.value.trim()
      if (!email) { setError('Please enter your email.'); return }

      sendBtn.setAttribute('aria-busy', 'true')
      sendBtn.disabled = true
      sendBtn.textContent = 'Sending…'
      clearError()

      try {
        const res = await fetch('/api/portal-link', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        })
        if (!res.ok) {
          const data = await res.json().catch(() => ({}))
          setError(data.error ?? 'Could not send link. Please try again.')
          return
        }
        result.classList.add('visible')
        result.scrollIntoView({ behavior: 'smooth', block: 'nearest' })
      } catch {
        setError('Network error — please try again.')
      } finally {
        sendBtn.removeAttribute('aria-busy')
        sendBtn.disabled = false
        sendBtn.textContent = 'Send link'
      }
    })
  </script>
</StandaloneLayout>
