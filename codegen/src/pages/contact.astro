---
import StandaloneLayout from '../layouts/StandaloneLayout.astro'
export const prerender = false

const type = Astro.url.searchParams.get('type') ?? 'general'

const config = {
  opensource: {
    label: 'Open Source License',
    heading: 'Apply for a free Open Source license',
    subtext:
      'Tell us about your project and where to find it. We review every application personally — usually within a few business days.',
    placeholder: "Link to your repo, a short description, and the email you'd like the license sent to.",
    buttonText: 'Send application',
  },
  enterprise: {
    label: 'Enterprise Inquiry',
    heading: "Let's talk enterprise",
    subtext:
      "Volume pricing, self-hosted validation, custom contracts, air-gapped environments — describe what you need and we'll get back to you within one business day.",
    placeholder: 'Your team size, environment constraints, and any specific requirements.',
    buttonText: 'Send inquiry',
  },
  general: {
    label: 'General',
    heading: 'Get in touch',
    subtext: "We read every message. Drop us a note and we'll reply promptly.",
    placeholder: 'How can we help?',
    buttonText: 'Send message',
  },
} as const

type ConfigKey = keyof typeof config
const cfg = config[(type in config ? type : 'general') as ConfigKey]
---
<StandaloneLayout title={`${cfg.label} — codegen`} description={cfg.subtext}>
  <style>
    main {
      max-width: 540px;
      margin: 0 auto;
      padding: var(--page-space-16) var(--page-space-6) var(--page-space-24);
    }

    .back {
      display: inline-flex;
      align-items: center;
      gap: var(--page-space-1-5);
      color: var(--page-text-muted);
      text-decoration: none;
      font-size: var(--page-font-size-sm);
      margin-bottom: var(--page-space-10);
      transition: color 0.15s;
    }
    .back:hover { color: var(--page-text); }

    h1 {
      font-size: 1.8rem;
      font-weight: var(--page-font-weight-extrabold);
      letter-spacing: -0.03em;
      margin-bottom: var(--page-space-2);
      color: var(--page-text);
    }
    .subtext {
      color: var(--page-text-muted);
      font-size: var(--page-font-size-sm);
      margin-bottom: var(--page-space-10);
      line-height: var(--page-line-height-relaxed);
    }

    /* Form */
    form { display: flex; flex-direction: column; gap: var(--page-space-5); }

    label {
      display: flex;
      flex-direction: column;
      gap: var(--page-space-1-5);
      font-size: var(--page-font-size-sm);
      font-weight: var(--page-font-weight-semibold);
      color: var(--page-text);
    }
    label span {
      color: var(--page-text-muted);
      font-weight: var(--page-font-weight-normal);
      font-size: var(--page-font-size-xs);
    }

    input[type="text"],
    input[type="email"],
    textarea {
      background: var(--page-bg-secondary);
      border: 1px solid var(--page-border);
      border-radius: var(--page-radius-lg);
      padding: 0.75rem var(--page-space-4);
      font-size: var(--page-font-size-sm);
      font-family: var(--page-font-family);
      color: var(--page-text);
      outline: none;
      transition: border-color 0.15s;
      width: 100%;
      resize: vertical;
    }
    input[type="text"]:focus,
    input[type="email"]:focus,
    textarea:focus { border-color: var(--page-accent); }
    ::placeholder { color: var(--page-text-muted); }
    textarea { min-height: 140px; }

    .field-error {
      font-size: var(--page-font-size-xs);
      color: var(--page-error);
      display: none;
      margin-top: var(--page-space-0-5);
    }
    .field-error.visible { display: block; }

    /* Success state */
    #success {
      display: none;
      background: color-mix(in srgb, var(--page-success) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--page-success) 25%, transparent);
      border-radius: var(--page-radius-xl);
      padding: var(--page-space-6);
      margin-top: var(--page-space-6);
    }
    #success.visible { display: block; }
    #success strong { display: block; color: var(--page-success); margin-bottom: var(--page-space-1-5); }
    #success p { color: var(--page-text-muted); font-size: var(--page-font-size-sm); }
  </style>

  <main>
    <a href="/pricing" class="back">← Back to pricing</a>

    <div class="page-badge page-badge-default" style="margin-bottom: var(--page-space-4);">{cfg.label}</div>
    <h1>{cfg.heading}</h1>
    <p class="subtext">{cfg.subtext}</p>

    <form id="contact-form" novalidate>
      <label>
        Name
        <input type="text" name="name" id="name" autocomplete="name" required />
        <span id="name-error" class="field-error">Please enter your name.</span>
      </label>

      <label>
        Email
        <input type="email" name="email" id="email" autocomplete="email" required />
        <span id="email-error" class="field-error">Please enter a valid email address.</span>
      </label>

      <label>
        Message
        <span>{cfg.placeholder}</span>
        <textarea name="message" id="message" required></textarea>
        <span id="message-error" class="field-error">Please write a short message.</span>
      </label>

      <input type="hidden" name="type" value={type} />

      <div>
        <button type="submit" id="submit-btn" class="page-button page-button-primary page-button-lg">
          {cfg.buttonText}
        </button>
      </div>
    </form>

    <div id="success" role="status" aria-live="polite">
      <strong>Message received — thank you!</strong>
      <p>We'll get back to you at the email you provided, usually within a couple of business days.</p>
    </div>
  </main>

  <script>
    const form = document.getElementById('contact-form')!
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement
    const successEl = document.getElementById('success')!

    function showFieldError(id: string, show: boolean) {
      document.getElementById(id)!.classList.toggle('visible', show)
    }

    function validate() {
      const name    = (document.getElementById('name')    as HTMLInputElement).value.trim()
      const email   = (document.getElementById('email')   as HTMLInputElement).value.trim()
      const message = (document.getElementById('message') as HTMLTextAreaElement).value.trim()
      const emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)

      showFieldError('name-error',    !name)
      showFieldError('email-error',   !emailOk)
      showFieldError('message-error', !message)

      return name && emailOk && message
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      if (!validate()) return

      submitBtn.setAttribute('aria-busy', 'true')
      submitBtn.disabled = true
      submitBtn.textContent = 'Sending…'

      // TODO: replace with real API call (POST /api/contact or Formspree endpoint)
      await new Promise((r) => setTimeout(r, 600))

      form.style.display = 'none'
      successEl.classList.add('visible')
      successEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' })
    })

    ;['name', 'email', 'message'].forEach((field) => {
      document.getElementById(field)!.addEventListener('input', () => {
        showFieldError(`${field}-error`, false)
      })
    })
  </script>
</StandaloneLayout>
