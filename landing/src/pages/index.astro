---
// Self-hosted Inter (bundled woff2 — no third-party round-trip, no layout
// shift). Weights used across the page.
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/600.css";
import "@fontsource/inter/700.css";
import "@fontsource/inter/800.css";
import "../styles/landing.css";

// Outbound destinations — codegen docs live on their own subdomain (microfrontend).
const CODEGEN_URL = "https://codegen.codexx-dtdk.com";
const EARLY_ACCESS_MAILTO =
  "mailto:support@codexx-dtdk.com?subject=CodeXX%20DTDK%20early%20access";

// Inline SVG icons (24×24 viewBox → identical, perfectly centred box per icon).
// Stroke = currentColor so they inherit theme text color.
const icons = {
  document: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"/><path d="M14 3v5h5"/><path d="M9 13h6M9 17h6"/></svg>`,
  code: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M9 8l-4 4 4 4"/><path d="M15 8l4 4-4 4"/></svg>`,
  shield: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z"/><path d="M9.5 12l1.8 1.8L15 10"/></svg>`,
  cube: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l8 4.5v9L12 21l-8-4.5v-9z"/><path d="M4 7.5l8 4.5 8-4.5"/><path d="M12 12v9"/></svg>`,
  open: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M14 5h5v5"/><path d="M19 5l-7 7"/><path d="M19 14v3a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h3"/></svg>`,
};

// Status reflects real component versions (clis/*/version.json, libs/linter, codexx_mcp_server).
const products = [
  {
    icon: "document",
    name: "Docs generator",
    desc: "A modern documentation from source solution, generating MDX files tailored to the Astro + Starlight tech stack, supporting cross-file linking, code navigation and AI powered features.",
    badges: [
      { cls: "badge-free", label: "Free" },
      { cls: "badge-shipped", label: "Shipping soon" },
    ],
    featured: false,
  },
  {
    icon: "code",
    name: "Code Generator",
    desc: "A one-stop solution for all tasks requiring large amounts of boilerplate. Built on an innovative no DSL AST transform based model, the tool enables advanced RTTI infrastructure, automatic generation of serialization and deserialization methods, self-documenting components... and much more.",
    badges: [{ cls: "badge-shipped", label: "Shipping soon" }],
    featured: true,
    href: CODEGEN_URL,
  },
  {
    icon: "shield",
    name: "Linter",
    desc: "Our most ambitious product yet. Possible only thanks to our inter-procedural, thread-aware CFG, our linter won't just include the usual safety and compliance checks, our final goal is full borrow-checking for existing C++. Moreover the linter will reuse our proven scipting engine model to enable the creation of custom rules.",
    badges: [{ cls: "badge-dev", label: "In development" }],
    featured: false,
  },
  {
    icon: "cube",
    name: "MCP server",
    desc: "For LLM-driven C++ workflows. Enables deep and efficient codebase knowledge thanks to tight integration with our proprietary engine and the use of advanced techniques and modern solutions for LLM instrumentation.",
    badges: [{ cls: "badge-dev", label: "In development" }],
    featured: false,
  },
];

// Grounded proof points — see plan: ~120k LoC, 49 ADRs (docs/ADRs), 4 products.
const proof = [
  { number: "120k+", label: "Lines of C++" },
  { number: "53", label: "Architecture decision records" },
  { number: "V1", label: "docsgen + codegen shipping" },
  { number: "4", label: "Integrated products ecosystem" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>CodeXX DTDK — a legacy-free C++ developer tooling platform</title>
    <meta
      name="description"
      content="The Dev-Tools Dev-Kit for C++. The foundational SDK and surrounding ecosystem of tools. Trying to build a nicer DX with QOL features and advanced safety and compliance tools for C++."
    />
  </head>
  <body>
    <script is:inline>
      // Shared with the codegen site via the `starlight-theme` key so the chosen
      // theme carries across the www ↔ codegen subdomains.
      const saved = localStorage.getItem("starlight-theme");
      const dark = saved
        ? saved === "dark"
        : window.matchMedia("(prefers-color-scheme: dark)").matches;
      document.documentElement.dataset.theme = dark ? "dark" : "light";
    </script>

    <h1 class="sr-only">CodeXX DTDK — a legacy-free C++ developer tooling platform</h1>

    <div class="wrap">
      <nav class="nav">
        <span class="nav-logo">CodeXX DTDK</span>
        <div class="nav-links">
          <a href={EARLY_ACCESS_MAILTO}>Early access</a>
        </div>
      </nav>

      <header class="hero">
        <h1>A legacy-free C++ developer tooling platform</h1>
        <p>
          The foundation for a new generation of developer tools for the C++ ecosystem.
        </p>
        <div class="hero-cta">
          <a class="btn-primary" href={EARLY_ACCESS_MAILTO}>Request early access</a>
        </div>
      </header>

      <section class="section engine" data-aos="fade-up">
        <div class="engine-head">
          <div class="engine-q">
            <span class="engine-eyebrow">The real question</span>
            <h2 class="engine-title">What bogs down the C++ tooling ecosystem?</h2>
          </div>
          <span class="engine-solution">The&nbsp;answer</span>
        </div>
        <p class="engine-body">
          C++ tooling has long been gated behind compiler front-ends — heavy, slow to
          adapt, built for compilation rather than understanding.
          <strong>CodeXX is a single, legacy-free engine</strong> that owns the whole
          path from source to control-flow. Owning that foundation is what unlocks the
          rest: documentation, code generation, and memory-safety analysis stop being
          separate research efforts and become tools you can actually pick up and use.
        </p>
      </section>

      <section class="section" data-aos="fade-up">
        <div class="section-label">Products</div>
        <div class="products">
          {
            products.map((p, i) => {
              const Tag = p.href ? "a" : "div";
              return (
                <Tag
                  class={["product-card", p.featured && "featured", p.href && "linked"]
                    .filter(Boolean)
                    .join(" ")}
                  data-aos="fade-up"
                  data-aos-delay={i * 60}
                  {...(p.href ? { href: p.href, "aria-label": `${p.name} docs` } : {})}
                >
                  {p.href && (
                    <span class="product-ext" aria-hidden="true" set:html={icons.open} />
                  )}
                  <div class="icon-wrap" aria-hidden="true" set:html={icons[p.icon as keyof typeof icons]} />
                  <div class="product-badges">
                    {p.badges.map((b) => (
                      <span class={`badge ${b.cls}`}>{b.label}</span>
                    ))}
                  </div>
                  <div class="product-name">{p.name}</div>
                  <div class="product-desc">{p.desc}</div>
                </Tag>
              );
            })
          }
        </div>
      </section>

      <section class="section" data-aos="fade-up">
        <div class="section-label">By the numbers</div>
        <div class="proof-grid">
          {
            proof.map((m, i) => (
              <div class="proof-card" data-aos="fade-up" data-aos-delay={i * 60}>
                <div class="proof-number">{m.number}</div>
                <div class="proof-label">{m.label}</div>
              </div>
            ))
          }
        </div>
      </section>

      <section class="cta-section" data-aos="fade-up">
        <h2>Join the design partner program</h2>
        <p>
          Early access for C++ teams. Tight feedback loop, direct line to the author.
          Further materials available under NDA.
        </p>
        <div class="hero-cta">
          <a class="btn-primary" href={EARLY_ACCESS_MAILTO}>Request early access</a>
          <a class="btn-secondary" href="mailto:support@codexx-dtdk.com">support@codexx-dtdk.com</a>
        </div>
      </section>

      <footer class="footer">
        <span>© {new Date().getFullYear()} CodeXX DTDK</span>
        <span>William Karol Di Cioccio</span>
      </footer>
    </div>

    <script>
      import AOS from "aos";
      import "aos/dist/aos.css";

      // Reduced-motion users get no animation (AOS disabled → elements visible).
      AOS.init({
        duration: 600,
        easing: "ease-out-cubic",
        once: true,
        offset: 80,
        disable: () =>
          window.matchMedia("(prefers-reduced-motion: reduce)").matches,
      });
    </script>
  </body>
</html>
